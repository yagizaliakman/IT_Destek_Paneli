@using IT_Destek_Panel.Models
@model List<IT_Destek_Panel.Models.User>
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fa-solid fa-users text-primary"></i> Kullanıcı Yönetimi</h2>
        <a href="/Admin/Index" class="btn btn-secondary shadow-sm"><i class="fa-solid fa-arrow-left"></i> Panele Dön</a>
    </div>

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover mt-3" id="akilliTablo">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Kullanıcı Adı</th>
                        <th>Rol</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-muted">@user.Id</td>
                            <td class="fw-bold">@user.Username</td>
                            <td>
                                @if (user.Role == UserRole.Admin)
                                {
                                    <span class="badge bg-danger shadow-sm"><i class="fa-solid fa-user-shield"></i> YÖNETİCİ</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary"><i class="fa-solid fa-user"></i> Öğrenci / User</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                @if (user.Role != UserRole.Admin)
                                {
                                    <a href="javascript:void(0);" onclick="kullaniciSil('@user.Id')" class="btn btn-sm btn-danger"><i class="fa-solid fa-trash"></i> Sil</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    function kullaniciSil(id) {
    Swal.fire({
    title: 'Emin misiniz?',
    text: "Bu kullanıcı sistemden tamamen kaldırılacaktır!",
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#d33',
    cancelButtonColor: '#6c757d',
    confirmButtonText: 'Evet, Sil!',
    cancelButtonText: 'İptal',
    // Dark mode uyumu için dinamik renkler
    background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#2b3035' : '#fff',
    color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#f8f9fa' : '#212529'
    }).then((result) => {
    if (result.isConfirmed) {
    // AdminController'daki DeleteUser metoduna ID'yi gönderiyoruz
    window.location.href = '/Admin/DeleteUser/' + id;
    }
    })
    }

    function biletSil(id) {
    Swal.fire({
    title: 'Talebi Sil?',
    text: "Bu destek talebi kalıcı olarak silinecektir!",
    icon: 'error',
    showCancelButton: true,
    confirmButtonColor: '#d33',
    cancelButtonColor: '#6c757d',
    confirmButtonText: 'Sil gitsin!',
    cancelButtonText: 'Vazgeç',
    background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#2b3035' : '#fff',
    color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#f8f9fa' : '#212529'
    }).then((result) => {
    if (result.isConfirmed) {
    // AdminController'daki DeleteTicket metoduna yönlendiriyoruz
    window.location.href = '/Admin/DeleteTicket/' + id;
    }
    })
    }
</script>
