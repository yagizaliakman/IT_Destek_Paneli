@model string

<div class="d-flex align-items-center me-4 px-3 py-1 rounded bg-dark border border-secondary shadow-sm">
    <i class="fa-solid fa-cloud-sun text-warning me-2 fs-5"></i>
    <div class="d-flex flex-column lh-1">
        <span class="text-white-50 text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px;">@ViewBag.City</span>
        <span class="text-white fw-bold" style="font-size: 0.95rem;">@Model °C</span>
    </div>
</div>